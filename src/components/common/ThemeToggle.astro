<button
  id="theme-toggle"
  class="p-2 rounded-full hover:bg-white/10 transition-colors flex items-center justify-center w-9 h-9"
  aria-label="Toggle Theme"
>
  <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
  <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
  <svg id="icon-navy" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="12" rx="10" ry="4" transform="rotate(-20 12 12)"/><circle cx="12" cy="12" r="3"/></svg>
</button>
<script>
  const THEMES = ['light', 'dark', 'navy'];

  function applyTheme(theme) {
    const el = document.documentElement;
    el.classList.remove('dark', 'navy');
    if (theme === 'dark') el.classList.add('dark');
    if (theme === 'navy') el.classList.add('navy');
    localStorage.setItem('theme', theme);

    document.getElementById('icon-sun').style.display = theme === 'light' ? 'block' : 'none';
    document.getElementById('icon-moon').style.display = theme === 'dark' ? 'block' : 'none';
    document.getElementById('icon-navy').style.display = theme === 'navy' ? 'block' : 'none';
  }

  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    const saved = localStorage.getItem('theme') || 'light';
    applyTheme(saved);

    btn?.addEventListener('click', () => {
      const current = localStorage.getItem('theme') || 'light';
      const idx = THEMES.indexOf(current);
      const next = THEMES[(idx + 1) % THEMES.length];
      applyTheme(next);
    });
  }

  initThemeToggle();
  document.addEventListener('astro:page-load', initThemeToggle);
</script>
