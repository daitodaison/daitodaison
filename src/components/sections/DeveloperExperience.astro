---
interface Props {
  title: string;
  features: string[];
  terminal: {
    comment: string;
    command: {
      tool: string;
      args: string;
    };
    successSteps: string[];
    readyMessage: string;
  };
}

const { title, features, terminal } = Astro.props;
const commandPayload = JSON.stringify({
  tool: terminal.command.tool,
  args: terminal.command.args
}, null, 2);
---
<div class="mt-24 p-12 rounded-[40px] bg-gradient-to-br from-slate-100 via-white to-white dark:from-zinc-950 dark:via-zinc-950 dark:to-zinc-950 border border-gray-200 dark:border-white/10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
            <h2 class="text-2xl md:text-3xl font-bold mb-6">{title}</h2>
            <ul class="space-y-4">
                {features.map(item => (
                    <li class="flex items-center gap-3 text-gray-600 dark:text-gray-300">
                        <div class="w-1.5 h-1.5 rounded-full bg-slate-900 dark:bg-white"></div>
                        {item}
                    </li>
                ))}
            </ul>
        </div>
        <div class="bg-zinc-900 rounded-2xl border border-white/10 p-6 font-mono text-sm overflow-hidden min-w-0">
            <div class="flex gap-2 mb-4">
                <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
                <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
            </div>
            <div class="text-blue-400"># {terminal.comment}</div>
            <pre class="mt-4 rounded-2xl bg-slate-950/90 p-4 text-sm text-white/80 overflow-x-auto whitespace-pre-wrap">
{commandPayload}
            </pre>
            {terminal.successSteps.map(step => (
                 <div class="text-emerald-400">✓ {step}</div>
            ))}
            <div class="mt-4 text-white animate-pulse">{terminal.readyMessage} _</div>
        </div>
    </div>
</div>
