---
export const prerender = true;
import Layout from '~/layouts/Layout.astro';
import ScrollProgress from '~/components/layout/ScrollProgress.astro';
import { client } from '~/library/microcms';
import { isRtl, useTranslations } from '~/i18n/utils';
import { languages } from '~/i18n/ui';
import translate from 'translate';

translate.engine = 'google';

export async function getStaticPaths() {
  const response = await client.get({ endpoint: 'blogs' });
  const posts = response.contents;
  return posts.flatMap((post: any) =>
    Object.keys(languages).map((lang) => ({
      params: { lang, id: post.id },
      props: { post, allPosts: posts },
    }))
  );
}

const { post, allPosts } = Astro.props;
const { lang } = Astro.params;
const t = useTranslations(lang);

async function translateHtml(htmlText: string, targetLang: string) {
  if (!htmlText) return '';
  try {
    const placeholders: string[] = [];
    let placeholderIndex = 0;
    const maskedHtml = htmlText.replace(/<[^>]+>/g, (match) => {
      placeholders.push(match);
      return ` [[${placeholderIndex++}]] `;
    });
    const translatedMasked = await translate(maskedHtml, { from: 'ja', to: targetLang });
    const finalHtml = translatedMasked.replace(/\[\[(\d+)\]\]/g, (_match: string, indexStr: string) => {
      return placeholders[parseInt(indexStr, 10)] || _match;
    });
    return finalHtml;
  } catch (error) {
    console.error('Google translation failed:', error);
    return htmlText;
  }
}

let displayTitle = post.title;
let displayContent = post.content;

if (lang === 'en') {
  try {
    displayTitle = await translate(post.title, { from: 'ja', to: 'en' });
    displayContent = await translateHtml(post.content, 'en');
  } catch (e) {
    console.error('Translation run error:', e);
  }
}

function extractHeadings(html: string) {
  const headings: { id: string; text: string; level: number }[] = [];
  const regex = /<h([23])[^>]*>(.*?)<\/h[23]>/gi;
  let match;
  while ((match = regex.exec(html)) !== null) {
    const level = parseInt(match[1]);
    const text = match[2].replace(/<[^>]+>/g, '');
    const id = text.replace(/\s+/g, '-').replace(/[^\w\u3040-\u9fff\-]/g, '').toLowerCase() || 'heading-' + headings.length;
    headings.push({ id, text, level });
  }
  return headings;
}

function addHeadingIds(html: string, headings: { id: string; text: string; level: number }[]) {
  let i = 0;
  return html.replace(/<h([23])([^>]*)>(.*?)<\/h[23]>/gi, (_match, level, attrs) => {
    const h = headings[i++];
    if (!h) return _match;
    return `<h${level}${attrs} id="${h.id}">${h.text}</h${level}>`;
  });
}

const headings = extractHeadings(displayContent);
displayContent = addHeadingIds(displayContent, headings);
const otherPosts = (allPosts as any[]).filter((p: any) => p.id !== post.id).slice(0, 3);
---

<Layout title={displayTitle} description={displayTitle} image={post.eyecatch?.url} imageAlt={displayTitle} article={true}>
  <ScrollProgress />

  <div class="max-w-7xl mx-auto px-4 pt-32 pb-20">

    <!-- 戻るリンク -->
    <div class="mb-6">
      <a href={`/${lang}/blog/microcms`} class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        {t['blog.back']}
      </a>
    </div>

    <!-- アイキャッチ -->
    {post.eyecatch && (
      <div class="rounded-2xl overflow-hidden mb-8 border border-black/10 dark:border-white/10 shadow-xl">
        <img src={post.eyecatch.url} alt={displayTitle} loading="eager" class="w-full object-cover aspect-video" />
      </div>
    )}

    <!-- タイトル -->
    <h1 class="text-2xl md:text-4xl font-bold mb-10 leading-tight text-zinc-900 dark:text-white">
      {displayTitle}
    </h1>

    <!-- 3カラムレイアウト -->
    <div class="flex gap-8 items-start">

      <!-- 左サイドバー：記事一覧 -->
      <aside class="hidden xl:block w-52 shrink-0 sticky top-24 space-y-4">
        <div class="bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-xl p-4">
          <p class="text-xs font-bold uppercase tracking-widest text-primary mb-3">攻略ブログ</p>
          <ul class="space-y-1">
            {(allPosts as any[]).map((p: any) => (
              <li>
                
                  href={`/${lang}/blog/microcms/${p.id}`}
                  class={"block text-xs leading-snug py-1.5 px-2 rounded-lg transition-colors " + (p.id === post.id ? "bg-primary/10 text-primary font-semibold" : "text-gray-600 dark:text-gray-400 hover:text-primary hover:bg-gray-100 dark:hover:bg-white/5")}
                >
                  {p.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-gradient-to-br from-primary to-blue-600 rounded-xl p-4 text-white">
          <p class="text-xs font-bold mb-1">🎁 限定特典</p>
          <p class="text-sm font-semibold mb-3">ツール完全版を無料解放中</p>
          <a href="https://astro.space/ja/" class="block text-center bg-white text-primary text-xs font-bold py-2 px-3 rounded-lg hover:bg-white/90 transition-colors">
            今すぐ口座開設
          </a>
        </div>
      </aside>

      <!-- 本文 -->
      <main class="min-w-0 flex-1">
        <div
          class="prose prose-base md:prose-lg max-w-none
            prose-headings:font-bold prose-headings:text-zinc-900 dark:prose-headings:text-white
            prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:pb-2 prose-h2:border-b prose-h2:border-gray-200 dark:prose-h2:border-white/10
            prose-h3:text-lg prose-h3:mt-6 prose-h3:mb-3
            prose-p:text-gray-700 dark:prose-p:text-gray-300 prose-p:leading-relaxed
            prose-li:text-gray-700 dark:prose-li:text-gray-300
            prose-a:text-primary prose-a:no-underline hover:prose-a:underline
            prose-strong:text-zinc-900 dark:prose-strong:text-white
            prose-img:rounded-xl prose-img:shadow-lg
            dark:prose-invert"
          set:html={displayContent}
        />

        <!-- 記事下CTA -->
        <div class="mt-16 rounded-2xl bg-gradient-to-br from-primary/10 via-blue-500/5 to-transparent border border-primary/20 p-8 text-center">
          <p class="text-xs font-bold uppercase tracking-widest text-primary mb-2">🎁 当サイト限定特典</p>
          <h3 class="text-xl font-bold mb-3 text-zinc-900 dark:text-white">ASTROサインツール完全版を無料で手に入れる</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 mb-6">当サイト経由でASTROに口座開設するだけで、22種類以上の指標搭載ツールと高勝率プリセットを完全無料でプレゼント。</p>
          <a href="https://astro.space/ja/" class="inline-flex items-center gap-2 bg-primary text-white font-bold px-8 py-4 rounded-full hover:bg-primary/90 transition-colors shadow-lg shadow-primary/20">
            今すぐ無料で口座開設する →
          </a>
        </div>

        <!-- 関連記事 -->
        {otherPosts.length > 0 && (
          <div class="mt-12">
            <h2 class="text-lg font-bold mb-4 text-zinc-900 dark:text-white">関連記事</h2>
            <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {otherPosts.map((p: any) => (
                <a href={`/${lang}/blog/microcms/${p.id}`} class="group block rounded-xl border border-gray-200 dark:border-white/10 overflow-hidden hover:border-primary/40 transition-colors">
                  {p.eyecatch && (
                    <img src={p.eyecatch.url} alt={p.title} class="w-full aspect-video object-cover group-hover:scale-105 transition-transform duration-300" />
                  )}
                  <div class="p-4">
                    <p class="text-sm font-semibold text-zinc-900 dark:text-white line-clamp-2 group-hover:text-primary transition-colors">{p.title}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        )}
      </main>

      <!-- 右サイドバー：目次＋CTA -->
      <aside class="hidden lg:block w-52 shrink-0 sticky top-24 space-y-4">
        {headings.length > 0 && (
          <div class="bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-xl p-4">
            <p class="text-xs font-bold uppercase tracking-widest text-primary mb-3">目次</p>
            <ul class="space-y-0.5" id="toc-list">
              {headings.map((h) => (
                <li>
                  
                    href={"#" + h.id}
                    data-toc-id={h.id}
                    class={"toc-link flex items-start gap-2 text-xs leading-snug py-1.5 px-2 rounded-lg transition-all duration-200 hover:text-primary hover:bg-primary/5 text-gray-500 dark:text-gray-400" + (h.level === 3 ? " pl-4" : "")}
                  >
                    <span class="toc-bar mt-1.5 shrink-0 w-0.5 h-2.5 rounded-full bg-transparent transition-all duration-200"></span>
                    <span>{h.text}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
        <div class="bg-gradient-to-br from-primary to-blue-600 rounded-xl p-4 text-white">
          <p class="text-xs font-bold mb-1">🎁 限定特典</p>
          <p class="text-sm font-semibold mb-3">ツール完全版を無料解放中</p>
          <a href="https://astro.space/ja/" class="block text-center bg-white text-primary text-xs font-bold py-2 px-3 rounded-lg hover:bg-white/90 transition-colors">
            今すぐ口座開設
          </a>
        </div>
      </aside>

    </div>
  </div>

  <script>
    const headingEls = Array.from(document.querySelectorAll('main h2[id], main h3[id]')) as HTMLElement[];
    const tocLinks = Array.from(document.querySelectorAll('a[data-toc-id]')) as HTMLAnchorElement[];

    function setActive(id: string) {
      tocLinks.forEach((link) => {
        const bar = link.querySelector('.toc-bar') as HTMLElement | null;
        if ((link as any).dataset.tocId === id) {
          link.classList.add('text-primary', 'font-semibold', 'bg-primary/5');
          link.classList.remove('text-gray-500');
          if (bar) bar.style.backgroundColor = '#2563EB';
        } else {
          link.classList.remove('text-primary', 'font-semibold', 'bg-primary/5');
          link.classList.add('text-gray-500');
          if (bar) bar.style.backgroundColor = 'transparent';
        }
      });
    }

    function onScroll() {
      const scrollY = window.scrollY + 140;
      let current = headingEls[0]?.id ?? '';
      for (const el of headingEls) {
        if ((el as HTMLElement).offsetTop <= scrollY) current = el.id;
        else break;
      }
      if (current) setActive(current);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  </script>
</Layout>
