---
export const prerender = true;
import Layout from '~/layouts/Layout.astro';
import ScrollProgress from '~/components/layout/ScrollProgress.astro';
import { client } from '~/library/microcms';
import { isRtl } from '~/i18n/utils';
import { languages } from '~/i18n/ui';

export async function getStaticPaths() {
  const response = await client.get({ endpoint: 'blogs' });
  const posts = response.contents;

  return posts.flatMap((post: any) =>
    Object.keys(languages).map((lang) => ({
      params: { lang, id: post.id },
      props: { post },
    }))
  );
}

const { post } = Astro.props;
const { lang } = Astro.params;
---

<Layout title={post.title} description={post.title}>
  <ScrollProgress />
  <article class="max-w-4xl mx-auto px-6 pt-40 pb-20">
    <div class="mb-8">
      <a href={`/${lang}/blog/microcms`} class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-primary transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={`w-4 h-4 ${isRtl(lang) ? 'rotate-180' : ''}`}><path d="m15 18-6-6 6-6"/></svg>
        ブログに戻る
      </a>
    </div>

    <div class="mb-12 text-center">
      {post.eyecatch && (
        <div class="rounded-2xl overflow-hidden mb-8 border border-black/10 dark:border-white/10 shadow-2xl">
          <img src={post.eyecatch.url} alt={post.title} class="w-full object-cover aspect-video" />
        </div>
      )}

      <h1 class="text-3xl md:text-6xl font-display font-bold mb-6 break-words bg-linear-to-br from-zinc-900 via-zinc-900 to-zinc-600 dark:from-white dark:via-white dark:to-white bg-clip-text text-transparent">
        {post.title}
      </h1>

      <hr class="border-black/10 dark:border-white/10" />
    </div>

    <div class="prose prose-lg mx-auto prose-img:rounded-xl prose-headings:font-display prose-headings:font-bold prose-a:text-primary hover:prose-a:text-primary/80 dark:prose-invert" set:html={post.content} />
  </article>
</Layout>