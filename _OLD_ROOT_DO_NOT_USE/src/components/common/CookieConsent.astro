---
import { Cookie, X } from 'lucide-react';
import { defaultLang } from '~/i18n/ui';
import { useTranslations } from '~/i18n/utils';
const { lang = defaultLang } = Astro.params;
const t = useTranslations(lang);
const positionClasses = 'md:left-6 md:right-auto';
---
<div id="cookie-consent" class={`fixed bottom-4 left-3 right-3 md:bottom-6 md:left-auto md:right-auto md:w-[400px] z-50 p-5 rounded-2xl bg-white dark:bg-zinc-900 backdrop-blur-xl border border-gray-200 dark:border-white/10 shadow-2xl opacity-0 translate-y-12 pointer-events-none transition-all duration-500 ease-out ${positionClasses}`} role="alert" dir="ltr">
  <div class="flex items-start gap-3">
    <div class="p-2.5 rounded-full bg-primary/10 text-primary shrink-0">
      <Cookie className="w-5 h-5" />
    </div>
    <div class="flex-1 min-w-0">
      <div class="text-base font-bold mb-1.5 text-gray-900 dark:text-white">{t['cookie.title']}</div>
      <p class="text-xs text-gray-500 dark:text-gray-400 mb-4 leading-relaxed">
        {t['cookie.description']}
      </p>
      <div class="flex gap-2">
        <button
          id="cookie-accept"
          class="flex-1 py-2.5 bg-primary text-white text-sm font-bold rounded-full hover:scale-105 transition-transform"
        >
          {t['cookie.accept']}
        </button>
        <button
          id="cookie-decline"
          class="flex-1 py-2.5 bg-gray-100 dark:bg-white/10 text-gray-700 dark:text-gray-200 text-sm font-bold rounded-full border border-gray-200 dark:border-white/10 hover:bg-gray-200 dark:hover:bg-white/20 transition-colors"
        >
          {t['cookie.decline']}
        </button>
      </div>
    </div>
    <button
      id="cookie-close"
      class="text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-white transition-colors p-1 shrink-0"
      aria-label="Close cookie banner"
    >
      <X className="w-5 h-5" />
    </button>
  </div>
</div>
<script>
  function initCookieConsent() {
    const banner = document.getElementById('cookie-consent');
    const acceptBtn = document.getElementById('cookie-accept');
    const declineBtn = document.getElementById('cookie-decline');
    const closeBtn = document.getElementById('cookie-close');
    if (!banner || !acceptBtn || !declineBtn || !closeBtn) return;
    const showBanner = () => {
        banner.classList.remove('opacity-0', 'translate-y-12', 'pointer-events-none');
        banner.classList.add('opacity-100', 'translate-y-0');
    };
    const hideBanner = () => {
        banner.classList.remove('opacity-100', 'translate-y-0');
        banner.classList.add('opacity-0', 'translate-y-12', 'pointer-events-none');
    };
    const consent = localStorage.getItem('cookie_consent');
    if (!consent) {
        setTimeout(showBanner, 1000);
    }
    acceptBtn.addEventListener('click', () => {
        localStorage.setItem('cookie_consent', 'accepted');
        window.dispatchEvent(new CustomEvent('consent:granted'));
        hideBanner();
    });
    declineBtn.addEventListener('click', () => {
        localStorage.setItem('cookie_consent', 'declined');
        hideBanner();
    });
    closeBtn.addEventListener('click', () => {
        localStorage.setItem('cookie_consent', 'declined');
        hideBanner();
    });
  }
  initCookieConsent();
  document.addEventListener('astro:page-load', initCookieConsent);
</script>
