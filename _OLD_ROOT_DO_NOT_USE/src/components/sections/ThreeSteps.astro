---
import { useTranslations } from '../../i18n/utils';
const { lang = 'ja' } = Astro.params;
const t = useTranslations(lang);
---
<section class="py-24 bg-white dark:bg-zinc-950">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mx-auto max-w-2xl mb-12">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-primary/70 mb-4">{t['steps.badge']}</p>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 dark:text-white mb-4">{t['steps.title']}</h2>
      <p class="text-gray-600 dark:text-gray-400">{t['steps.subtitle']}</p>
    </div>
    <div class="grid gap-6 md:grid-cols-3">
      <div class="rounded-3xl border border-gray-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 p-8 text-center flex flex-col gap-4">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-primary/10 text-primary text-lg font-bold">1</div>
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white">{t['steps.1.title']}</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">{t['steps.1.desc']}</p>
      </div>
      <div class="rounded-3xl border border-gray-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 p-8 text-center flex flex-col gap-4">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-primary/10 text-primary text-lg font-bold">2</div>
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white">{t['steps.2.title']}</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">{t['steps.2.desc']}</p>
      </div>
      <div class="rounded-3xl border border-gray-200 dark:border-white/10 bg-slate-50 dark:bg-white/5 p-8 text-center flex flex-col gap-4">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-primary/10 text-primary text-lg font-bold">3</div>
        <h3 class="text-xl font-semibold text-slate-900 dark:text-white">{t['steps.3.title']}</h3>
        <p class="text-sm text-gray-600 dark:text-gray-400">{t['steps.3.desc']}</p>
      </div>
    </div>
    <div class="mt-10 text-center">
      <a href="https://astro.space/ja/" class="inline-flex items-center justify-center rounded-full bg-primary px-8 py-4 text-sm font-semibold text-white shadow-lg shadow-primary/20 transition hover:bg-primary/90">
        {t['steps.cta']}
      </a>
    </div>
  </div>
</section>
