---
interface Props {
  id: string;
  message: string;
  link?: string;
  linkText?: string;
}
const { message, link, linkText } = Astro.props;
---
<div 
  id="announcement-banner" 
  class="bg-primary text-white relative overflow-hidden"
  role="alert"
>
  <!-- PC: 中央寄せ静止表示 -->
  <div class="hidden md:flex items-center justify-center px-6 py-2 gap-4">
    <span class="text-sm font-medium">{message}</span>
    {link && (
      <a 
        href={link} 
        class="shrink-0 text-xs font-bold bg-white text-primary px-3 py-1 rounded-full hover:bg-white/90 transition-all whitespace-nowrap"
      >
        {linkText}
      </a>
    )}
  </div>

  <!-- スマホ: マーキースクロール表示 -->
  <div class="flex md:hidden items-center justify-between px-4 py-2 gap-3">
    <div class="flex-1 overflow-hidden">
      <div class="marquee-wrapper">
        <div class="marquee-track text-sm font-medium">
          <span class="marquee-item">{message}&nbsp;&nbsp;&nbsp;</span>
          <span class="marquee-item">{message}&nbsp;&nbsp;&nbsp;</span>
        </div>
      </div>
    </div>
    {link && (
      <a 
        href={link} 
        class="shrink-0 text-xs font-bold bg-white text-primary px-3 py-1 rounded-full hover:bg-white/90 transition-all whitespace-nowrap"
      >
        {linkText}
      </a>
    )}
  </div>
</div>

<style is:global>
  .marquee-wrapper {
    overflow: hidden;
  }

  .marquee-track {
    display: inline-flex;
    align-items: center;
    animation: announcement-marquee 18s linear infinite !important;
    will-change: transform;
  }

  .marquee-item {
    display: inline-flex;
    white-space: nowrap;
  }

  @keyframes announcement-marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @media (min-width: 768px) {
    .marquee-track {
      animation: none !important;
    }
  }
</style>
