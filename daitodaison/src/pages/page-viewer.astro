---
// /page-viewer?slug=roadmap でアクセス
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ページ | daitodaison</title>
  <style>
    :root { --color-heading: #4a9eff; --color-text: #e0e0e0; --color-bg: #292c32; }
    body { background: var(--color-bg); color: var(--color-text); font-family: sans-serif; margin: 0; }
    .page-container { max-width: 860px; margin: 0 auto; padding: 2rem 1rem; }
    h1 { font-size: 1.8rem; margin-bottom: 2rem; color: var(--color-heading); }
    .content-body { line-height: 1.8; }
    .content-body h2 { font-size: 1.4rem; margin: 2rem 0 1rem; color: var(--color-heading); }
    .content-body p { margin-bottom: 1rem; }
    .content-body a { color: #4a9eff; }
    .loading { text-align: center; padding: 4rem; color: #888; }
    .error { text-align: center; padding: 4rem; color: #f66; }
  </style>
</head>
<body>
  <div id="app"><div class="loading">読み込み中...</div></div>
  <script>
    (async () => {
      const params = new URLSearchParams(location.search);
      const slug = params.get('slug') || '';
      const app = document.getElementById('app');
      if (!slug) {
        app.innerHTML = '<div class="error">slugが指定されていません</div>';
        return;
      }
      try {
        const res = await fetch(
          'https://daitodaison.microcms.io/api/v1/pages?filters=slug[equals]' +
          encodeURIComponent(slug) + '&limit=1&fields=title,content',
          { headers: { 'X-MICROCMS-API-KEY': 'xPnAHYwXkxMz8dA0obaE79otSJzlWElii3wQ' } }
        );
        const data = await res.json();
        if (!data.contents || data.contents.length === 0) {
          app.innerHTML = '<div class="error">ページが見つかりません: ' + slug + '</div>';
          return;
        }
        const page = data.contents[0];
        document.title = page.title + ' | daitodaison';
        app.innerHTML =
          '<div class="page-container"><article>' +
          '<h1>' + page.title + '</h1>' +
          '<div class="content-body">' + (page.content || '') + '</div>' +
          '</article></div>';
      } catch (e) {
        app.innerHTML = '<div class="error">エラー: ' + e.message + '</div>';
      }
    })();
  </script>
</body>
</html>
