---
export const prerender = true;
import { languages, defaultLang } from '~/i18n/ui';
import { useTranslations } from '~/i18n/utils';
import Layout from '~/layouts/Layout.astro';
import { client } from '~/library/microcms';

export async function getStaticPaths() {
  return Object.keys(languages).map((lang) => ({ params: { lang } }));
}

const { lang = defaultLang } = Astro.params;

// 最新記事3件取得
let latestPosts: any[] = [];
try {
  const res = await client.get({ endpoint: "blogs", queries: { limit: 3, fields: "id,title,eyecatch,category,content" } });
  latestPosts = res.contents;
} catch(e) {}
---

<Layout title="daito | 勝率40%・上位2.3%のFXトレーダーが教えるプロップ攻略" description="Fintokei上位2.3%入賞（2587人中61位）のFXトレーダーが、プロップファーム攻略・FX戦略をSubstackで無料公開中。">

  <!-- HERO -->
  <section class="relative bg-gradient-to-br from-zinc-950 via-blue-950 to-zinc-900 text-white pt-32 pb-20 px-4 overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(circle_at_30%_50%,#2563eb,transparent_60%)]"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <div class="inline-flex items-center gap-2 bg-blue-500/20 border border-blue-500/30 rounded-full px-4 py-1.5 text-sm text-blue-300 mb-6">
        🏆 Fintokei大会 上位2.3%入賞（2587人中61位）
      </div>
      <h1 class="text-3xl md:text-5xl font-black leading-tight mb-6">
        自己資金ゼロで<br class="md:hidden"/>
        <span class="text-blue-400">プロの資金</span>を動かす<br/>
        FXプロップ攻略法
      </h1>
      <p class="text-lg text-zinc-300 max-w-2xl mx-auto mb-8 leading-relaxed">
        勝率40%でも上位2.3%に入れる理由とは？<br/>
        Fintokei・FTMO・Funded7の攻略戦略をSubstackで無料公開中。
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://daitodaison.substack.com/" target="_blank" rel="noopener"
           class="inline-flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-bold px-8 py-4 rounded-xl transition-all hover:-translate-y-0.5 shadow-lg shadow-blue-500/20">
          📬 Substackを無料購読する
        </a>
        <a href={`/${lang}/blog/`}
           class="inline-flex items-center justify-center gap-2 bg-white/10 hover:bg-white/20 border border-white/20 text-white font-bold px-8 py-4 rounded-xl transition-all hover:-translate-y-0.5">
          📖 攻略ブログを読む
        </a>
      </div>
      <!-- 実績数字 -->
      <div class="grid grid-cols-3 gap-4 mt-16 max-w-lg mx-auto">
        <div class="bg-white/5 border border-white/10 rounded-xl p-4">
          <p class="text-2xl font-black text-blue-400">2.3%</p>
          <p class="text-xs text-zinc-400 mt-1">Fintokei上位</p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-xl p-4">
          <p class="text-2xl font-black text-blue-400">40%</p>
          <p class="text-xs text-zinc-400 mt-1">勝率</p>
        </div>
        <div class="bg-white/5 border border-white/10 rounded-xl p-4">
          <p class="text-2xl font-black text-blue-400">756+</p>
          <p class="text-xs text-zinc-400 mt-1">攻略記事</p>
        </div>
      </div>
    </div>
  </section>

  <!-- プロップファーム比較 -->
  <section class="py-20 px-4 bg-zinc-50 dark:bg-zinc-900">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-black text-center mb-4 text-zinc-900 dark:text-white">
        おすすめプロップファーム3選
      </h2>
      <p class="text-center text-zinc-500 dark:text-zinc-400 mb-12">自己資金不要・合格すれば会社資金でトレードできる</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

        <!-- Fintokei -->
        <div class="relative bg-white dark:bg-zinc-800 rounded-2xl border-2 border-purple-400 p-6 shadow-lg">
          <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-purple-600 text-white text-xs font-bold px-4 py-1 rounded-full">🏆 著者イチオシ</div>
          <div class="text-center mb-4">
            <p class="text-3xl mb-2">🇯🇵</p>
            <h3 class="text-xl font-black text-zinc-900 dark:text-white">Fintokei</h3>
            <p class="text-sm text-zinc-500 mt-1">日本初・無料デモ大会あり</p>
          </div>
          <ul class="space-y-2 mb-6 text-sm text-zinc-600 dark:text-zinc-300">
<li>✅ 利益配分80〜100%（ポイントステージ制）</li>
<li>✅ 最大5,000万円の運用資金</li>
<li>✅ MT4・MT5・cTrader・TradingView対応</li>
<li>✅ 参加費全額返金（2026年6月末まで）</li>
          </ul>
          <a href="https://www.fintokei.com/jp/?affiliate=64" target="_blank" rel="noopener"
             class="block text-center bg-purple-600 hover:bg-purple-500 text-white font-bold py-3 rounded-xl transition-all">
            無料で始める →
          </a>
        </div>

        <!-- FUNDED7 -->
        <div class="bg-white dark:bg-zinc-800 rounded-2xl border border-zinc-200 dark:border-zinc-700 p-6 shadow-sm">
          <div class="text-center mb-4">
            <p class="text-3xl mb-2">7️⃣</p>
            <h3 class="text-xl font-black text-zinc-900 dark:text-white">FUNDED7</h3>
            <p class="text-sm text-zinc-500 mt-1">1フェーズ・速攻プランあり</p>
          </div>
          <ul class="space-y-2 mb-6 text-sm text-zinc-600 dark:text-zinc-300">
<li>✅ 最大6,000万円・利益配分最大90%</li>
<li>✅ 業界最狭スプレッド（ドル円0.1pips）</li>
<li>✅ MT5・DXtrade（TradingView内蔵）対応</li>
<li>✅ 違反即失格なし・育てる姿勢のOREF制度</li>
          </ul>
          <a href="https://my.funded7.com/ja/sign-up?affiliateId=111" target="_blank" rel="noopener"
             class="block text-center bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-xl transition-all">
            アカウント開設 →
          </a>
        </div>

        <!-- FTMO -->
        <div class="bg-white dark:bg-zinc-800 rounded-2xl border border-zinc-200 dark:border-zinc-700 p-6 shadow-sm">
          <div class="text-center mb-4">
            <p class="text-3xl mb-2">🌍</p>
            <h3 class="text-xl font-black text-zinc-900 dark:text-white">FTMO</h3>
            <p class="text-sm text-zinc-500 mt-1">世界最大手・300万人以上</p>
          </div>
          <ul class="space-y-2 mb-6 text-sm text-zinc-600 dark:text-zinc-300">
<li>✅ 累計690億円超の出金実績・世界最大手</li>
<li>✅ 最大約3億円（スケーリング込み）</li>
<li>✅ 利益配分80〜90%・14日ごと出金</li>
<li>✅ 2015年創業・Trustpilot4.8の圧倒的信頼</li>
          </ul>
          <a href="https://trader.ftmo.com/?affiliates=fEZqWBlMdBrTtxUjIJYD" target="_blank" rel="noopener"
             class="block text-center bg-zinc-700 hover:bg-zinc-600 text-white font-bold py-3 rounded-xl transition-all">
            無料トライアル →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- 最新記事 -->
  {latestPosts.length > 0 && (
    <section class="py-20 px-4 bg-white dark:bg-zinc-950">
      <div class="max-w-5xl mx-auto">
        <h2 class="text-2xl md:text-3xl font-black text-center mb-4 text-zinc-900 dark:text-white">最新の攻略記事</h2>
        <p class="text-center text-zinc-500 dark:text-zinc-400 mb-12">プロップファーム攻略・FX戦略を毎週更新</p>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestPosts.map((post: any) => {
            const raw = post.eyecatch || "";
            let imgUrl = raw.split("|")[0].replace("https://daitodaison.pages.dev/wp-content", "https://dysonblog.org/wp-content");
            if (!imgUrl && post.content) {
              const match = post.content.match(/<img[^>]+src=["']([^"']+)["']/i);
              if (match) {
                imgUrl = match[1].replace("https://daitodaison.pages.dev/wp-content", "https://dysonblog.org/wp-content");
              }
            }
            return (
              <a href={`/${lang}/blog/microcms/${post.id}`}
                 class="group block bg-zinc-50 dark:bg-zinc-800 rounded-2xl overflow-hidden border border-zinc-200 dark:border-zinc-700 hover:border-blue-400 hover:shadow-lg transition-all hover:-translate-y-1">
                {imgUrl && (
                  <div class="aspect-video overflow-hidden">
                    <img src={imgUrl} alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  </div>
                )}
                <div class="p-4">
                  <p class="text-sm font-semibold text-zinc-900 dark:text-white line-clamp-3 group-hover:text-blue-600 transition-colors">{post.title}</p>
                </div>
              </a>
            );
          })}
        </div>
        <div class="text-center mt-10">
          <a href={`/${lang}/blog/`} class="inline-flex items-center gap-2 bg-zinc-900 dark:bg-white dark:text-zinc-900 text-white font-bold px-8 py-4 rounded-xl hover:-translate-y-0.5 transition-all">
            すべての記事を見る →
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- Substack CTA -->
  <section class="py-20 px-4 bg-gradient-to-br from-blue-600 to-blue-800 text-white">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-sm font-bold uppercase tracking-widest text-blue-200 mb-3">📬 無料ニュースレター</p>
      <h2 class="text-2xl md:text-3xl font-black mb-4">プロップ攻略の知見を<br/>無料で受け取る</h2>
      <p class="text-blue-100 mb-8 leading-relaxed">
        Fintokei上位2.3%の攻略戦略をSubstackで公開中。<br/>
        トレード日誌・相場分析・EA開発まで、実践的な情報を毎週お届け。
      </p>
      <a href="https://daitodaison.substack.com/" target="_blank" rel="noopener"
         class="inline-flex items-center gap-2 bg-white text-blue-700 font-black px-10 py-4 rounded-xl hover:-translate-y-0.5 transition-all shadow-lg">
        Substackを無料購読する →
      </a>
      <p class="text-blue-200 text-sm mt-4">無料・いつでも解除可能</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 px-4 bg-zinc-50 dark:bg-zinc-900">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-2xl md:text-3xl font-black text-center mb-12 text-zinc-900 dark:text-white">よくある質問</h2>
      <div class="space-y-4">
        {[
          { q: "プロップファームって何ですか？", a: "会社の資金でトレードできる仕組みです。参加費を払いテストに合格すると、数百万〜数千万円の会社資金でトレードでき、利益の大部分を受け取れます。" },
          { q: "自己資金がなくても始められますか？", a: "はい。プロップファームは参加費（数万円）だけで始められます。合格すれば自己資金をリスクにさらさずに大きな資金でトレードできます。" },
          { q: "勝率40%でも稼げるんですか？", a: "はい。重要なのは勝率より損益比率（リスクリワード）です。1回の損失を小さく、1回の利益を大きくすれば、勝率40%でも十分プロップテストに合格できます。" },
          { q: "Substackは本当に無料ですか？", a: "基本コンテンツは完全無料です。登録するだけでFintokei攻略戦略・相場分析・トレード日誌を受け取れます。" },
        ].map((item) => (
          <details class="bg-white dark:bg-zinc-800 rounded-xl border border-zinc-200 dark:border-zinc-700 p-5 group">
            <summary class="font-bold text-zinc-900 dark:text-white cursor-pointer list-none flex justify-between items-center">
              {item.q}
              <span class="text-blue-500 group-open:rotate-45 transition-transform text-xl">+</span>
            </summary>
            <p class="mt-3 text-zinc-600 dark:text-zinc-300 text-sm leading-relaxed">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

</Layout>
