---
export const prerender = true;
import Layout from '~/layouts/Layout.astro';
import PageHeader from '~/components/layout/PageHeader.astro';
import Container from '~/components/ui/Container.astro';
import Card from '~/components/ui/Card.astro';
import { client } from '~/library/microcms';
import { useTranslations } from '~/i18n/utils';

export async function getStaticPaths() {
  console.log('[blog/index] getStaticPaths開始');
  const response = await client.get({ endpoint: 'blogs' });
  console.log('[blog/index] 取得件数:', response.contents.length);
  const posts = response.contents;
  return [
    { params: { lang: 'ja' }, props: { posts } },
    { params: { lang: 'en' }, props: { posts } },
  ];
}

const { posts } = Astro.props;
const { lang } = Astro.params;
const t = useTranslations(lang);
---
<Layout title="Blog" description={t['blog.microcms.desc']}>
  <PageHeader title="Blog" description={t['blog.microcms.desc']} />
  <Container as="section" class="pb-24">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      {posts.map((post: any) => (
        <Card href={`/${lang}/blog/microcms/${post.id}`} class="p-0 overflow-hidden block h-full group">
          <div class="p-6">
            <h2 class="text-xl font-bold">{post.title}</h2>
          </div>
        </Card>
      ))}
    </div>
  </Container>
</Layout>
