---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { defaultLang } from '~/i18n/ui';

interface Props {
  author: CollectionEntry<'authors'>;
}

const { author } = Astro.props;
const { name, description, avatar, social } = author.data;
const { lang = defaultLang } = Astro.params;

// Extract slug from ID (e.g., "en/joseph-cooper" -> "joseph-cooper")
const authorSlug = author.id.split('/').slice(1).join('/');
const authorLink = `/${lang}/blog/author/${authorSlug}`;
---

<div class="mt-16 p-8 rounded-2xl bg-foreground/5 border border-foreground/10 relative overflow-hidden group">
  {/* Subtle background glow */}
  <div class="absolute -top-24 -right-24 w-48 h-48 bg-primary/10 rounded-full blur-3xl group-hover:bg-primary/20 transition-colors duration-500"></div>
  
  <div class="flex flex-col md:flex-row items-center md:items-start gap-8 relative z-10">
    <div class="shrink-0">
      <a href={authorLink} class="block relative w-24 h-24 md:w-32 md:h-32 rounded-2xl overflow-hidden ring-4 ring-background shadow-xl">
        <Image 
          src={avatar} 
          alt={name} 
          width={256} 
          height={256} 
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
        />
      </a>
    </div>
    
    <div class="flex-1 text-center md:text-left">
      <a href={authorLink} class="inline-block group/link">
        <h3 class="text-2xl font-bold text-foreground mb-2 group-hover/link:text-primary transition-colors">{name}</h3>
      </a>
      <p class="text-muted-foreground leading-relaxed mb-6">
        {description}
      </p>
      
      {social && (
        <div class="flex items-center justify-center md:justify-start gap-4">
          {social.twitter && (
            <a href={social.twitter} target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-primary transition-colors" aria-label={`Follow ${name} on Twitter`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
            </a>
          )}
          {social.linkedin && (
            <a href={social.linkedin} target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-primary transition-colors" aria-label={`Follow ${name} on LinkedIn`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
          )}
          {social.github && (
            <a href={social.github} target="_blank" rel="noopener noreferrer" class="text-muted-foreground hover:text-primary transition-colors" aria-label={`Follow ${name} on GitHub`}>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            </a>
          )}
        </div>
      )}
    </div>
  </div>
</div>
