---
import { siteConfig, ACTION_LINKS, FOOTER_LINKS } from '~/site.config';
import BrandIcon from '~/components/common/BrandIcon.astro';
import { defaultLang } from '~/i18n/ui';
import { useTranslations } from '~/i18n/utils';

const today = new Date();
const { lang = defaultLang } = Astro.params;
const t = useTranslations(lang);
---

<footer class="mt-auto border-t border-gray-200 dark:border-white/10 bg-white dark:bg-[#141820] py-12">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-12">
      <div class="col-span-1 md:col-span-2 flex flex-col items-start gap-4">
        <div class="flex flex-col gap-2">
          <span class="text-xl font-bold font-display tracking-tight">{t['brand.name'] || siteConfig.name}</span>
          <p class="text-sm text-gray-500 dark:text-gray-400 max-w-xs">
            {t['footer.quote']}
          </p>
        </div>

        <div class="mt-4 w-full">
          <p class="text-xs text-gray-500 dark:text-gray-          <p class="text-xs text-gray-500 dark:text-gray-400 mb-3">自己資金不要・合格すれば会社資金でトレードできる</p>
          <a href="https://www.fintokei.com/jp/?affiliate=64" target="_blank" rel="noopener" class="group flex items-center gap-3 max-w-sm w-full bg-gradient-to-br from-purple-500/10 to-pink-500/5 border border-purple-300 dark:border-purple-500/30 rounded-xl p-3 hover:border-purple-500 transition-all">
            <div class="shrink-0 w-10 h-10 rounded-lg bg-purple-500/10 flex items-center justify-center text-lg">🏆</div>
            <div class="min-w-0">
              <p class="text-xs font-bold text-zinc-900 dark:text-white leading-snug line-clamp-2">Fintokei（フィントケイ）で無料登録する</p>
              <p class="text-[11px] text-purple-600 font-medium mt-0.5">日本初の本格派プロップファーム →</p>
            </div>
          </a>
        </div>
      </div>
      
      {Object.entries(FOOTER_LINKS).map(([key, section]) => (
        <div>
          <div class="font-semibold mb-4 text-gray-900 dark:text-white">{t[`footer.${key}` as keyof typeof t] || section.title}</div>
          <ul class="space-y-2 text-sm text-gray-900/90 dark:text-white/90">
            {section.links.map((link: any) => {
              
              const shouldLocalize = link.localize !== false;
              const href = (!shouldLocalize)
                ? link.href 
                : `/${lang}${link.href.startsWith('/') ? '' : '/'}${link.href}`.replace(/\/$/, '') || `/${lang}`;
              
              return (
                <li>
                  <a 
                    href={href} 
                    class="inline-flex items-center px-2 py-2 rounded-md hover:text-slate-900 dark:hover:text-white transition-colors"
                    aria-label={(link.key && t[`footer.${link.key}` as keyof typeof t]) || link.label}
                  >
                    {(link.key && t[`footer.${link.key}` as keyof typeof t]) || link.label}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))}
    </div>

    <div class="pt-8 border-t border-gray-200 dark:border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <div class="text-gray-500 dark:text-gray-400 text-sm">
        {(t['footer.copyright'] || '').replace('{year}', today.getFullYear().toString())}
      </div>
      
      <div class="flex gap-4">
        <a href={ACTION_LINKS.social.linkedin} target="_blank" rel="noopener noreferrer" class="text-gray-500 dark:text-gray-400 hover:text-slate-900 dark:hover:text-white transition-colors p-2 rounded-full hover:bg-slate-100 dark:hover:bg-white/10" aria-label="LinkedIn">
          <BrandIcon icon="linkedin" className="w-5 h-5" strokeWidth={1.5} />
        </a>
        <a href={ACTION_LINKS.social.youtube} target="_blank" rel="noopener noreferrer" class="text-gray-500 dark:text-gray-400 hover:text-slate-900 dark:hover:text-white transition-colors p-2 rounded-full hover:bg-slate-100 dark:hover:bg-white/10" aria-label="YouTube">
          <BrandIcon icon="youtube" className="w-5 h-5" strokeWidth={1.5} />
        </a>
        <a href={ACTION_LINKS.social.github} target="_blank" rel="noopener noreferrer" class="text-gray-500 dark:text-gray-400 hover:text-slate-900 dark:hover:text-white transition-colors p-2 rounded-full hover:bg-slate-100 dark:hover:bg-white/10" aria-label="GitHub">
          <BrandIcon icon="github" className="w-5 h-5" strokeWidth={1.5} />
        </a>
       <a href={ACTION_LINKS.social.note} target="_blank" rel="noopener noreferrer" class="text-gray-500 dark:text-gray-400 hover:text-slate-900 dark:hover:text-white transition-colors p-2 rounded-full hover:bg-slate-100 dark:hover:bg-white/10" aria-label="note">
          <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor" aria-hidden="true"><rect width="24" height="24" rx="6"/><text x="12" y="16.5" font-size="12" font-weight="bold" fill="white" text-anchor="middle" font-family="sans-serif">n</text></svg>
        </a>
        <a href={ACTION_LINKS.social.substack} target="_blank" rel="noopener noreferrer" class="text-gray-500 dark:text-gray-400 hover:text-slate-900 dark:hover:text-white transition-colors p-2 rounded-full hover:bg-slate-100 dark:hover:bg-white/10" aria-label="Substack">
          <svg viewBox="0 0 24 24" class="w-5 h-5" fill="currentColor" aria-hidden="true"><path d="M22.539 8.242H1.46V5.406h21.08v2.836zM1.46 10.812V24L12 18.11 22.54 24V10.812H1.46zM22.54 0H1.46v2.836h21.08V0z"/></svg>
        </a>
        <a href={ACTION_LINKS.social.twitter} target="_blank" rel="noopener noreferrer" class="text-gray-500 dark:text-gray-400 hover:text-slate-900 dark:hover:text-white transition-colors p-2 rounded-full hover:bg-slate-100 dark:hover:bg-white/10" aria-label="X (Twitter)">
          <BrandIcon icon="x" className="w-5 h-5" strokeWidth={1.5} />
        </a>
      </div>
    </div>
  </div>
</footer>
