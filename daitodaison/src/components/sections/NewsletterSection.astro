---
import { useTranslations } from '~/i18n/utils';
const { lang = 'ja' } = Astro.params;
const t = useTranslations(lang);
---
<section class="py-24 px-6">
  <div class="max-w-5xl mx-auto">
    <div class="relative group">
      <div class="absolute -inset-0.5 bg-gradient-to-r from-slate-900/20 via-sky-400/20 to-blue-500/20 dark:from-white/10 rounded-2xl blur-xl opacity-20 group-hover:opacity-40 transition duration-1000"></div>
      <div class="relative bg-white dark:bg-zinc-950 border border-gray-200 dark:border-white/10 rounded-2xl p-8 md:p-12 overflow-hidden shadow-2xl">
        <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-64 h-64 bg-slate-900/5 dark:bg-white/5 rounded-full blur-3xl"></div>
        <div class="grid md:grid-cols-2 gap-8 items-center">
          <div>
            <p class="text-sm font-semibold uppercase tracking-widest text-primary/70 mb-3">{t['cta.badge'] || '無料で始める'}</p>
            <h2 class="text-2xl md:text-3xl font-bold mb-4">{t['newsletter.title']}</h2>
            <p class="text-gray-600 dark:text-gray-300 leading-relaxed">{t['newsletter.description']}</p>
          </div>
          <div class="flex flex-col gap-4">
            
              href="#"
              class="flex items-center gap-4 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-xl px-6 py-4 hover:border-primary/40 hover:bg-primary/5 transition-all group/card"
            >
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0 text-primary font-bold">M</div>
              <div>
                <p class="font-semibold text-sm">{t['newsletter.moppy.title'] || 'モッピーに無料登録'}</p>
                <p class="text-xs text-gray-500 dark:text-gray-400">{t['newsletter.moppy.desc'] || 'カード発行で5,000〜10,000pt獲得'}</p>
              </div>
              <svg class="ml-auto w-4 h-4 text-gray-400 group-hover/card:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
            
              href="#"
              class="flex items-center gap-4 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-xl px-6 py-4 hover:border-primary/40 hover:bg-primary/5 transition-all group/card"
            >
              <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center shrink-0 text-primary font-bold">H</div>
              <div>
                <p class="font-semibold text-sm">{t['newsletter.hapitas.title'] || 'ハピタスに無料登録'}</p>
                <p class="text-xs text-gray-500 dark:text-gray-400">{t['newsletter.hapitas.desc'] || '1pt=1円・交換手数料無料'}</p>
              </div>
              <svg class="ml-auto w-4 h-4 text-gray-400 group-hover/card:text-primary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
